# ---- Required ----

# Brave Search API key (free tier: https://brave.com/search/api/).
# Search needs either this OR the upstream proxy settings below.
BRAVE_SEARCH_API_KEY=

# No Brave key? Search through another LibreSearch instance instead.
# Ask its operator for a token, then set:
# UPSTREAM_SEARCH_URL=https://libresearch.ca
# UPSTREAM_SEARCH_TOKEN=
UPSTREAM_SEARCH_URL=
UPSTREAM_SEARCH_TOKEN=

# Operators only: serve /api/upstream/search to other instances.
# Comma-separated bearer tokens you issue (openssl rand -hex 24 each).
# Leave blank to keep the endpoint disabled.
UPSTREAM_SEARCH_TOKENS=

# Secret used to sign ALTCHA proof-of-work challenges (anti-abuse).
# Generate with: openssl rand -hex 32
ALTCHA_SECRET=

# ---- Optional features (leave blank to disable) ----

# AI answers via Groq.
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Stock widgets via Finnhub.
FINNHUB_API_KEY=

# Contact / feedback forms via Web3Forms.
PUBLIC_WEB3FORMS_KEY=

# Accounts (login/signup) via Appwrite — works with self-hosted Appwrite too.
PUBLIC_APPWRITE_ENDPOINT=
PUBLIC_APPWRITE_PROJECT_ID=
PUBLIC_APPWRITE_DB_ID=main
APPWRITE_API_KEY=

# Error reporting via Sentry. Unset = zero telemetry.
PUBLIC_SENTRY_DSN=

# ---- Optional infrastructure ----

# Redis (Upstash-compatible REST API) for cross-instance rate limiting and
# search caching. docker-compose provides this automatically; a single
# instance without Redis falls back to in-memory state and works fine.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Token for the bundled serverless-redis-http proxy (docker-compose only).
REDIS_HTTP_TOKEN=change-me

# ---- Self-hosted server tuning (adapter-node) ----
# PORT=3000
# Trust client IPs from your reverse proxy:
# ADDRESS_HEADER=x-forwarded-for
# XFF_DEPTH=1
