# Copy to `.env.local` and fill in. Never commit real values.

# Required — Brave Search API key. Get one at https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Required — secret used to sign ALTCHA proof-of-work challenges. Keep private.
# Generate one with: openssl rand -hex 32
ALTCHA_SECRET=

# Required for the /contact form — Web3Forms access key. Public by design
# (Web3Forms expects this to be browser-visible).
PUBLIC_WEB3FORMS_KEY=

# Optional — soft per-instance daily cap on upstream Brave queries to bound API
# spend. 0 or unset = no cap. A durable cap across serverless instances needs
# external state (KV/Redis); this guards a single warm instance only.
BRAVE_DAILY_QUERY_CAP=0

# Optional — Sentry DSN for error reporting. Unset = errors are logged to stderr
# only (no external reporting).
PUBLIC_SENTRY_DSN=
